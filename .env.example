# Copy to .env.production.local for local production builds (do not commit secrets).

# Public site origin (no trailing slash) — canonical / Open Graph when vite injects meta
VITE_SITE_URL=https://pixellayer7-jpg.github.io/1

# Live quote calculator (Hero CTA + Process step)
VITE_ESTIMATOR_URL=https://pixellayer7-jpg.github.io/project-estimator/

# Formspree form id from https://formspree.io/f/<id> — leave empty to hide online form
VITE_FORMSPREE_FORM_ID=

# Optional estimator-api base for POST /api/v1/leads (no trailing slash)
VITE_LEAD_API_URL=

# Optional booking link (Calendly, etc.)
VITE_BOOKING_URL=
